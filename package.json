{
  "name": "productivity-app",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean",
    "web": "pnpm --filter @productivity/web dev",
    "mobile": "pnpm --filter @productivity/mobile start",
    "mobile:ios": "pnpm --filter @productivity/mobile ios"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.5.0",
    "typescript": "~5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "@types/react": "~19.1.17",
      "@types/react-dom": "~19.1.0"
    }
  }
}
